[sub_resource type="GDScript" id="GDScript_w34uy"]
script/source = "#combat manager
extends Node2D
class_name CombatManager

@onready var root_UI : rootUI = $\"../CanvasLayer/RootUI\"
@onready var hand = $\"../CanvasLayer/RootUI/BottomHUD/UIRow/Hand\"

func _ready() -> void:
	call_deferred(\"spawn_char_UI\", \"res://Resource/Cavalry.tres\", \"PLAYER\", 1)
	call_deferred(\"spawn_char_UI\", \"res://Resource/Mushroom.tres\", \"ENEMY\", 5)
	
	#spawn_char_UI(\"res://Resource/Centaur.tres\", \"PLAYER\", 1)
	
	
func spawn_char_UI(char_res_dir, char_group, marker_index) -> void:
	root_UI.spawn_char_UI(char_res_dir, char_group, marker_index)
"

